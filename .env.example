# Скопируй в .env для локального запуска или задай те же ключи в Render / Vercel.

# --- Django ---
# DEBUG: не задан или true → режим разработки (по умолчанию). false → production.
# Локально можно не задавать DEBUG — будет True.
DEBUG=
SECRET_KEY=
# В production (DEBUG=false): ALLOWED_HOSTS обязателен, см. DEPLOY.md
ALLOWED_HOSTS=

# --- CORS / CSRF (для production; для Vercel укажи точный HTTPS origin без path) ---
# CORS_ALLOWED_ORIGINS=https://your-app.vercel.app
# CSRF_TRUSTED_ORIGINS=https://your-app.vercel.app

# --- База (опционально; если задано — PostgreSQL вместо SQLite) ---
# DATABASE_URL=postgres://user:pass@host:5432/dbname
